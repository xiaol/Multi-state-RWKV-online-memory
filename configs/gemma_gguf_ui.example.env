# Copy values from this file into your shell before launching the UI.
#
# Backend: start llama.cpp separately, then point the UI at its OpenAI API.
LLAMA_BASE_URL=http://127.0.0.1:8080/v1
LLAMA_MODEL=gemma-4-e4b-it-q8
LLAMA_SERVER_BIN=/run/media/xiaol/B214449214445C0B/tools/llama.cpp/build-cuda/bin/llama-server
LLAMA_REASONING=off

# Downloaded GGUF files on the 2 TB SSD.
GGUF_MODEL_PATH=/run/media/xiaol/B214449214445C0B/models/gguf/gemma-4-E4B-it/gemma-4-E4B-it-Q8_0.gguf
GGUF_MMPROJ_PATH=/run/media/xiaol/B214449214445C0B/models/gguf/gemma-4-E4B-it/mmproj-gemma-4-E4B-it-Q8_0.gguf

# UI and logs.
GGUF_UI_HOST=127.0.0.1
GGUF_UI_PORT=7860
GGUF_LOG_DIR=.openresearch/artifacts/gguf_ui
GGUF_REFERENCE_TRACE=.openresearch/artifacts/gguf_reference_trace_from_sidecar_64.json

# RWKV-MS sidecar UI mode. Uncomment together after starting the patched
# sidecar server with LLAMA_PORT=18083 and teeing logs to LLAMA_SERVER_LOG.
# The patched runtime rejects sidecars whose embedded base GGUF SHA-256 does
# not match GGUF_MODEL_PATH.
# LLAMA_BASE_URL=http://127.0.0.1:18083/v1
# LLAMA_MODEL=gemma-4-e4b-it-rwkv-ms-q8
# LLAMA_RWKV_MS=1
# GGUF_RWKV_MS_SIDECAR_PATH=/run/media/xiaol/B214449214445C0B/models/gguf/gemma-4-E4B-it/gemma-4-E4B-it-rwkv-ms-memory.gguf
# LLAMA_SERVER_LOG=.openresearch/artifacts/gguf_ui/llama_server_rwkv_ms.log
# LLAMA_SLOT_SAVE_PATH=.openresearch/artifacts/gguf_ui/slots
# GGUF_RWKV_MS_HEALTH_OUTPUT=.openresearch/artifacts/gguf_ui/rwkv_ms_runtime_health.json
# GGUF_UI_REQUIRE_RWKV_MS_HEALTH=1
# GGUF_UI_PORT=7861
